{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "generate-token",
      "type": "node",
      "request": "launch",
      "program": "index.ts",
      "args": [
        "generate-token",
        "--config-file-path",
        ".\\docs\\tests\\config\\08-ad-authorization-code-with-scripts-and-keyvault.json",
        "--env",
        "08-ad-authorization-code-with-scripts-and-keyvault",
        "--add-prefix-to-access-token",
        "--output-file-path",
        ".\\docs\\tests\\output-files\\settings.json",
        "--output-file-access-token-key",
        "'rest-client.environmentVariables'.'{env}'.'bearerToken'",
        "--output-file-refresh-token-key",
        "'rest-client.environmentVariables'.'{env}'.'refreshToken'",
        "--output-file-win-new-line-char"
      ],
      "runtimeExecutable": "tsx",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"]
    }
  ]
}
